# Fix4ever React Native App - Environment Variables Example
# Copy this file to .env and fill in your values

# API Configuration
API_BASE_URL=   
API_TIMEOUT=30000

# App Configuration
APP_NAME=
APP_VERSION=1.0.0

# Build Configuration (for Docker builds)
ANDROID_BUILD_TYPE=debug

# Keystore Configuration (for release builds - DO NOT COMMIT REAL VALUES!)
# KEYSTORE_FILE=/app/android/app/keystores/release.keystore
# KEYSTORE_PASSWORD=your_keystore_password
# KEY_ALIAS=your_key_alias
# KEY_PASSWORD=your_key_password

# Development
NODE_ENV=development
REACT_NATIVE_PACKAGER_HOSTNAME=0.0.0.0

GOOGLE_MAPS_API_KEY=

ENVIRONMENT=production
GOOGLE_MAPS_API_KEY=
CASHFREE_SANDBOX_URL=
CASHFREE_PRODUCTION_URL=
CASHFREE_ENVIRONMENT=sandbox

# Optional: Google Services
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_WEB_CLIENT_ID=your_google_web_client_id